{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "MaiBot 知识库",
  "description": "MaiBot 知识库插件：markdown 文档语义切分 + 向量/BM25 混合检索 + RRF 融合 + 自动注入，附 SQLite 存储抽象与 Web 管理界面。",
  "author": {
    "name": "MaiBot Community",
    "url": "https://github.com/cyhqw"
  },
  "license": "GPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/cyhqw/maikb",
    "homepage": "https://github.com/cyhqw/maikb",
    "documentation": "https://github.com/cyhqw/maikb",
    "issues": "https://github.com/cyhqw/maikb/issues"
  },
  "changelog": "CHANGELOG.md",
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    { "type": "python_package", "name": "sqlmodel", "version_spec": ">=0.0.24" },
    { "type": "python_package", "name": "sqlalchemy", "version_spec": ">=2.0.41" },
    { "type": "python_package", "name": "aiosqlite", "version_spec": ">=0.21.0" },
    { "type": "python_package", "name": "numpy", "version_spec": ">=1.24.0" },
    { "type": "python_package", "name": "fastapi", "version_spec": ">=0.100.0" },
    { "type": "python_package", "name": "uvicorn", "version_spec": ">=0.23.0" },
    { "type": "python_package", "name": "tomlkit", "version_spec": ">=0.12.0" }
  ],
  "capabilities": [
    "config.get",
    "llm.embed"
  ],
  "id": "maibot-team.maikb"
}
